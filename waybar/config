[
  {
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 5,
    "modules-left": [
      "hyprland/workspaces",
      "hyprland/window"
    ],
    "modules-right": [
      "battery",
      "cpu",
      "memory",
      "pulseaudio",
      "hyprland/language",
      "tray",
      "clock"
    ],
    "hyprland/window": {
      "format": "{class}",
      "rewrite": {
          "zen":	                 "  Zen Browser",
          "thunderbird":             "  Thunderbird",
          "com.mitchellh.ghostty":   "  Ghostty",
          "Bitwarden": 		         "  Bitwarden",
          "org.telegram.desktop":    "  Telegram",
          "org.gnome.Nautilus":      "  Nautilus",
          "Postman":                 "  Postman",
          "deepin-calculator":       "  Calculator",
          "google-chrome":           "  Chrome",
          "Pidgin":                  "  Pidgin",
          "wofi":                    "󰍉  Apps",
          "app.hiddify.com":         "󰦝  Hiddify",
          "Termius":                 "  Termius",
          "jetbrains-goland":        "  GoLand",
          "jetbrains-datagrip":      "  DataGrip"
        },
      "max-length": 30
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "warp-on-scroll": false,
        "format": "{name}"
    },
    "battery": {
        "format": "{icon}  {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "format-charging": " {capacity}%",
        "format-plugged":  " {capacity}%",
        "format-alt": "{icon}  {time}",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },
    "hyprland/language": {
        "format":    "  {}",
        "format-en": "EN",
        "format-ru": "RU"
    },
    "tray": {
      "spacing": 10
    },
    "clock": {
      "format": "{:%a, %d. %b  %H:%M:%S}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "interval": 1
    },
    "cpu": {
      "format": "cpu {usage}%"
    },
    "memory": {
      "format": "mem {}%"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon} {volume}%",
      "format-icons": {
        "default": [
          " ",
          " ",
          " "
        ]
      },
      "on-click": "pavucontrol",
    }
  },
]
